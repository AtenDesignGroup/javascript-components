{
  "name": "@atendesign/javascript-components",
  "version": "1.0.0",
  "description": "A collection of JavaScript libraries that adhere ceremoniously with WCAG guidelines.",
  "scope": "atendesign",
  "main": "dist/javascript-components.umd.js",
  "module": "dist/javascript-components.esm.js",
  "type": "module",
  "files": [
    "dist/",
    "src/"
  ],
  "scripts": {
    "build": "rollup -c",
    "dev": "rollup -c -w",
    "clean": "rm -rf dist",
    "prebuild": "npm run clean",
    "prepublishOnly": "npm run build"
  },
  "exports": {
    ".": {
      "import": "./dist/javascript-components.esm.js",
      "require": "./dist/javascript-components.umd.js"
    },
    "./src": "./src/index.js",
    "./components/Accordion": "./src/components/Accordion.js",
    "./components/TabContent": "./src/components/TabContent.js"
  },
  "author": "Philip Stier",
  "devDependencies": {
    "@babel/core": "^7.23.0",
    "@babel/preset-env": "^7.23.0",
    "@rollup/plugin-babel": "^6.0.4",
    "@rollup/plugin-commonjs": "^25.0.7",
    "@rollup/plugin-node-resolve": "^15.2.3",
    "@rollup/plugin-terser": "^0.4.4",
    "rollup": "^4.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AtenDesignGroup/javascript-components.git"
  },
  "bugs": {
    "url": "https://github.com/AtenDesignGroup/javascript-components/issues"
  },
  "homepage": "https://github.com/AtenDesignGroup/javascript-components#readme"
}
